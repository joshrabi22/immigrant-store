<div class="hero">
  {% if section.settings.image %}
    <img src="{{ section.settings.image | image_url: width: 1920 }}" alt="{{ section.settings.heading }}">
  {% else %}
    <div style="height: 70vh; background: #2c2c2c;"></div>
  {% endif %}
  <div class="hero-overlay">
    <h1 class="hero-title">{{ section.settings.heading | default: 'immigrant' }}</h1>
  </div>
</div>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "immigrant"
    }
  ]
}
{% endschema %}
