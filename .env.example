# Anthropic API key for Claude vision
ANTHROPIC_API_KEY=sk-ant-...

# Optional: anthropic model to use (defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# CJ Dropshipping API
CJ_API_KEY=CJ...
CJ_API_EMAIL=your@email.com

# Shopify
SHOPIFY_API_KEY=shpss_...
SHOPIFY_ACCESS_TOKEN=shpat_...
SHOPIFY_STORE_URL=your-store.myshopify.com

# remove.bg API (image background removal)
REMOVEBG_API_KEY=...

# Server port (default 3000)
PORT=3000

# Turso cloud database (optional — uses local file:data.db if not set)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=eyJ...
