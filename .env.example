# === IMMIGRANT STORE — Environment Variables ===
#
# Copy to .env and fill in values.
# For cloud dev on Railway, set these in the Railway dashboard instead.

# ---------------------------------------------------------------------------
# Ghost Logic Pipeline (required for processing)
# ---------------------------------------------------------------------------

# Anthropic API — Claude vision (Stage 3 naming, product membership gate, alistream junk filter)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override model (defaults to claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Photoroom API — Stage 1 extraction (primary)
PHOTOROOM_API_KEY=sk_pr_...

# remove.bg API — Stage 1 extraction (fallback)
REMOVEBG_API_KEY=...

# Gemini API — Stage 2 compositing (gemini-2.5-flash-image)
GEMINI_API_KEY=AIza...

# Cloudinary — processed image hosting (all Ghost Logic output)
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Turso cloud database (REQUIRED for cloud dev / Railway)
# Omit or leave empty for local SQLite (data.db)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=eyJ...

# ---------------------------------------------------------------------------
# Queue (optional — inline processing used when absent)
# ---------------------------------------------------------------------------

# Redis for BullMQ Ghost Logic queue
# Omit for local dev (processing runs inline in the request)
# Set for Railway production (Upstash Redis)
# REDIS_URL=rediss://...

# ---------------------------------------------------------------------------
# Shopify (required for publishing, not needed for curation workflow)
# ---------------------------------------------------------------------------

SHOPIFY_API_KEY=shpss_...
SHOPIFY_ACCESS_TOKEN=shpss_...
SHOPIFY_STORE_URL=22immigrant.myshopify.com

# ---------------------------------------------------------------------------
# CJ Dropshipping (not needed for curation workflow)
# ---------------------------------------------------------------------------

CJ_API_KEY=CJ...
CJ_API_EMAIL=your@email.com

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

PORT=3000
